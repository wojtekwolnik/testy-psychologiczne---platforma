# =============================================================
# TESTY PSYCHOLOGICZNE - Environment Variables Template
# =============================================================
# Copy this file to .env (for local dev) or set these as
# environment variables in your production environment.
# =============================================================

# --- Database ---
# Local dev (Docker Compose): postgresql://postgres:password@localhost:5432/testy_psychologiczne
# Production (VPS): postgresql://USER:PASSWORD@HOST:5432/DB_NAME
DATABASE_URL="postgresql://postgres:password@localhost:5432/testy_psychologiczne"

# --- Authentication ---
# REQUIRED: Generate a strong random secret (min 32 characters)
# Generate one with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-secret-key"

# --- Application ---
NODE_ENV="production"

# --- Email Notifications (Optional) ---
# If unset, email sending is disabled (notifications appear in-app only)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="your@email.com"
# SMTP_PASS="yourpassword"
# SMTP_FROM="noreply@example.com"
